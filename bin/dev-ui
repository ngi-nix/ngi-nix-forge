#!/usr/bin/env bash
set -u
rootDir=$(realpath "${0%/*}"/..)
cd "$rootDir"
unit=ngi_nix_dev
slice=session-${unit}
function clean {
  set +e
  systemctl --user stop ${slice}.slice
  systemctl --user reset-failed ${unit}-'*'.service
  rm -rf ui/build
}
function onExit {
  set +e
  clean
  systemctl --user stop ${slice}.slice
  systemctl --user reset-failed ${unit}-'*'.service
  watchman trigger-del . "$unit-config"
  watchman trigger-del . "$unit-options"
  watchman watch-del .
}

trap onExit EXIT
clean
set -ex
listenPort="${listenPort:-3000}"

mkdir -p "$rootDir/ui/build/js"

# Warning(correctness): when using `nix build`,
# be careful to either register the resulting output(s)
# in $rootDir/ui/build as roots to nix's garbage-collector (GC)
# by using `-o`, or to copy files out of the Nix store.
# Otherwise the GC can remove the results at any moment.

nix build \
  -f "$rootDir" \
  -o "$rootDir/ui/build/bootstrap" \
  _forge-ui.passthru.bootstrapCss

# Note: using `watchman watch-project`
# would not support working in a non-default git-worktree or jj-workspace.
# Remark(resiliency): if the systemd unit in watchman fails,
# `systemctl --user reset-failed`
# needs to be called (eg. by rerunning this script).
watchman watch .
watchman -j <<EOT
[ "trigger"
, "$PWD"
, {
    "name": "$unit-config",
    "command": [ "systemd-run", "--user", "--pipe", "--slice", "$slice", "-u", "${unit}-config"
               , "nix", "build", "-f", "$rootDir", "_forge-config", "-o", "$rootDir/ui/build/forge-config.json", "--show-trace"
               ],
    "append_files": false,
    "expression": [
      "anyof",
      [
        "match",
        "forge/**/*.nix",
        "wholename",
        {"includedotfiles": false}
      ],
      [
        "match",
        "recipes/**/*.nix",
        "wholename",
        {"includedotfiles": false}
      ]
    ]
  }
]
EOT
watchman -j <<EOT
[ "trigger"
, "$PWD"
, {
    "name": "$unit-options",
    "command": [ "systemd-run", "--user", "--pipe", "--slice", "$slice", "-u", "${unit}-options"
               , "nix", "build", "-f", "$rootDir", "_forge-options", "-o", "$rootDir/ui/build/forge-options.json", "--show-trace"
               ],
    "append_files": false,
    "expression": [
      "match",
      "forge/**/*.nix",
      "wholename",
      {"includedotfiles": false}
    ]
  }
]
EOT

systemd-run --user --slice "$slice" -u ${unit}-elm-watch \
  -p Environment=ELM_WATCH_HOST="${ELM_WATCH_HOST:-"127.0.0.1"}" \
  -p Environment=PATH="$(dirname "$(which elm-review)"):$PATH" \
  -p WorkingDirectory="$PWD/ui" \
  elm-watch hot

# Remark(correctness): esbuild never serves stale build results
# https://esbuild.github.io/api/#serve
#
# Remark(correctness): --serve-fallback= prevents 404 errors
# eg. on forge-config.json
systemd-run --user --slice "$slice" -u ${unit}-esbuild \
  -p WorkingDirectory="$PWD/ui" \
  esbuild \
  --bundle \
  --loader:.html=copy \
  --outbase=src \
  --outdir=build \
  --serve="${listenPort}" \
  --servedir=build \
  --serve-fallback=src/index.html \
  --sourcemap=external \
  --watch=forever \
  src/**/*.css \
  src/**/*.html \
  src/**/*.js

journalctl --since "-5s" --user -f \
  -u ${unit}-"*".service
